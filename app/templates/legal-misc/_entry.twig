{# Pages section entry template — misc pages (Privacy Policy, Terms, etc.).
   `entry` is always populated here since Craft only renders this template
   when a `pages` entry URL resolves. #}
{% extends '_layout' %}

{% block content %}
  {# pt-hero-top clears the absolutely-positioned site header #}
  <article class="container pt-page-top pb-4xl max-w-legal md:pt-page-top-md lg:pt-page-top-lg">
    <h1 class="type-subheadline mb-lg">{{ entry.title }}</h1>

    {% if entry.richText is defined and entry.richText %}
      <div class="rich-text">{{ entry.richText|typogrify|raw }}</div>
    {% endif %}
  </article>
{% endblock %}
