{#
  Temporary image placeholder — self-contained SVG data URI (no network).
  When CMS assets are wired up, replace call sites with `_partials/asset-media`
  (same slot, same wrapper) — see AGENTS.md.

  Params: text, width, height, class
#}
{% set width = width|default(800) %}
{% set height = height|default(600) %}
{% set svg %}<svg xmlns="http://www.w3.org/2000/svg" width="{{ width }}" height="{{ height }}"><rect width="100%" height="100%" fill="#d8d8d8"/><text x="50%" y="50%" fill="#6f6f6f" font-family="sans-serif" font-size="{{ max(16, (width / 24)|round) }}" text-anchor="middle" dominant-baseline="middle">{{ text|default('Image') }}</text></svg>{% endset %}
<img
  data-src="data:image/svg+xml;charset=utf-8,{{ svg|trim|url_encode }}"
  alt=""
  width="{{ width }}"
  height="{{ height }}"
  class="{{ class|default('') }} lazyload"
/>
