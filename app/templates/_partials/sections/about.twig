{% if entry.heading or entry.intro %}
<section id="about" class="bg-dark-red text-white">
  <div class="container py-5xl text-center md:py-6xl">
    {% if entry.heading %}
      <p class="type-eyebrow">{{ entry.heading }}</p>
    {% endif %}
    {% if entry.intro %}
      <div class="mx-auto mt-md max-w-[56ch] type-body-mono-big text-pretty">
        {{ entry.intro|typogrify|raw }}
      </div>
    {% endif %}
  </div>
</section>
{% endif %}
