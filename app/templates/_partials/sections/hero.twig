{% import '_partials/vite' as vite %}

<section class="relative overflow-hidden bg-brown">
  <img
    data-src="{{ vite.url('/images/texture-02.jpg') }}"
    alt=""
    aria-hidden="true"
    class="lazyload pointer-events-none absolute inset-0 h-full w-full object-cover mix-blend-multiply"
  />

  <div class="relative">
    <h1 class="container pt-hero-top md:pt-hero-top-md lg:pt-hero-top-lg text-red">
      {% include '_partials/svg-headline' with {
        text: hero.headlineA ~ ' ' ~ hero.headlineB,
        viewBoxHeight: 400,
        lines: [
          { text: hero.headlineA, y: 150, fontSize: 203, lengthAdjust: 'spacing' },
          { text: hero.headlineB, y: 398, fontSize: 312, lengthAdjust: 'spacingAndGlyphs' },
        ],
      } only %}
    </h1>

    <div class="relative mt-xl md:mt-2xl">
      <div class="pointer-events-none absolute bottom-full translate-y-[44%] left-[21%] z-10 w-[25vw] max-w-[160px] -rotate-10 md:left-[24%] md:w-[22vw] md:max-w-[210px] lg:w-[18vw] lg:max-w-[256px] lg:left-[28%]">
        <div data-headline-sticker>
          <img data-src="{{ vite.url('/images/sticker-no-preservatives.png') }}" alt="No artificial preservatives" class="lazyload h-auto w-full" />
        </div>
      </div>

      <div class="pointer-events-none absolute -top-sm left-[56%] md:left-[52%] lg:left-[52%] z-10 w-[25vw] max-w-[160px] rotate-10 md:-top-md md:w-[22vw] md:max-w-[210px] lg:w-[18vw] lg:max-w-[256px]">
        <div data-headline-sticker>
          <img data-src="{{ vite.url('/images/sticker-no-nitrates.png') }}" alt="No nitrates or nitrites added" class="lazyload h-auto w-full" />
        </div>
      </div>

      <div class="relative aspect-square w-full overflow-hidden md:aspect-[16/7] bg-dark-red" data-module="parallax">
      {% if entry.image|length %}
      {% set img = entry.image.one() %}
        <div class="absolute inset-x-0 -top-[10%] h-[120%] w-full overflow-hidden" data-parallax-media>
          {% include "_partials/asset-media" with { asset: img, extraClasses: 'lazyload absolute inset-0 h-full w-full object-cover' } only %}
        </div>
      {% else %}
        <img
            data-src="{{ vite.url('/images/pizza-bg.jpg') }}"
            alt="Close-up of a pepperoni pizza"
            data-parallax-media
            class="lazyload absolute inset-x-0 -top-[10%] h-[120%] w-full object-cover"
          />
        {% endif %}
      </div>
    </div>
  </div>
</section>
